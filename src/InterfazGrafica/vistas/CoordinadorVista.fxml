<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.geometry.Insets?>

<AnchorPane prefHeight="500.0" prefWidth="700.0"
            xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="InterfazGrafica.CoordinadorControlGUI">
    <children>


        <VBox layoutX="0.0" layoutY="0.0" prefHeight="500.0" prefWidth="180.0"
              style="-fx-background-color: #3a3a3a; -fx-padding: 15;">
            <children>
                <Label text="Registro" style="-fx-text-fill: white; -fx-font-size: 16; -fx-font-weight: bold;"/>
                <Label text="Coordinador" style="-fx-text-fill: #aaaaaa; -fx-font-size: 12;">
                    <VBox.margin><Insets top="4.0"/></VBox.margin>
                </Label>
            </children>
        </VBox>


        <VBox layoutX="180.0" layoutY="0.0" prefHeight="500.0" prefWidth="520.0"
              style="-fx-padding: 30;" spacing="10.0">
            <children>

                <Label text="Registro de Coordinador" style="-fx-font-size: 22; -fx-font-weight: bold;"/>

                <VBox fx:id="panelError" managed="false" prefWidth="450.0" spacing="4.0"
                      style="-fx-border-color: #8B0000; -fx-border-width: 2; -fx-background-color: #f5f5dc; -fx-padding: 10;"
                      visible="false">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label text="✖" style="-fx-text-fill: #8B0000; -fx-font-size: 14; -fx-font-weight: bold;"/>
                        <Label fx:id="etiquetaTituloError" style="-fx-font-weight: bold; -fx-text-fill: #8B0000;" text=""/>
                    </HBox>
                    <Label fx:id="etiquetaMensajeError" style="-fx-text-fill: #8B0000; -fx-font-size: 11;" text=""/>
                </VBox>

                <VBox fx:id="panelExito" managed="false" prefWidth="450.0" spacing="4.0"
                      style="-fx-border-color: #2d6a2d; -fx-border-width: 2; -fx-background-color: #f0f7f0; -fx-padding: 10;"
                      visible="false">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label text="✔" style="-fx-text-fill: #2d6a2d; -fx-font-size: 14; -fx-font-weight: bold;"/>
                        <Label fx:id="etquetaTituloExito" style="-fx-font-weight: bold; -fx-text-fill: #2d6a2d;" text=""/>
                    </HBox>
                    <Label fx:id="etiquetaMensajeExito" style="-fx-text-fill: #2d6a2d; -fx-font-size: 11;" text=""/>
                </VBox>

                <Label text="Nombre(s)" style="-fx-font-size: 13;">
                    <VBox.margin><Insets top="10.0"/></VBox.margin>
                </Label>
                <TextField fx:id="campoTextoNombres" prefHeight="30.0" prefWidth="450.0" promptText="Ej. Juan Carlos"/>

                <Label text="Apellidos" style="-fx-font-size: 13;"/>
                <TextField fx:id="campoTextoApellidos" prefHeight="30.0" prefWidth="450.0" promptText="Ej. Bonilla Pérez"/>

                <Label text="Número de personal" style="-fx-font-size: 13;"/>
                <TextField fx:id="campoTextoNumeroPersonal" prefHeight="30.0" prefWidth="450.0" promptText="Ej. 2232456"/>

                <HBox spacing="15.0">
                    <VBox.margin><Insets top="20.0"/></VBox.margin>
                    <Button fx:id="botonRegistrar" onAction="#botonRegistrar" prefWidth="140.0" prefHeight="35.0"
                            text="Registrar"
                            style="-fx-background-color: #2c3e50; -fx-text-fill: white; -fx-background-radius: 6;"/>
                    <Button fx:id="botonCancelarRegistro" onAction="#botonCancelar" prefWidth="140.0" prefHeight="35.0"
                            text="Cancelar"
                            style="-fx-background-color: #c0392b; -fx-text-fill: white; -fx-background-radius: 6;"/>
                </HBox>

            </children>
        </VBox>

        <Button fx:id="botonRegresar" layoutX="610.0" layoutY="10.0" onAction="#botonRegresar"
                prefHeight="28.0" prefWidth="75.0" text="Regresar"
                style="-fx-background-color: #7f8c8d; -fx-text-fill: white; -fx-background-radius: 6;"/>

    </children>
</AnchorPane>