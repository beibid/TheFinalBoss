<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="600.0" prefWidth="750.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="InterfazGrafica.EvaluacionReporteControlador">
    <children>


        <VBox layoutX="0.0" layoutY="0.0" prefHeight="602.0" prefWidth="180.0" style="-fx-border-color: black; -fx-background-color: #2ecc71; -fx-padding: 15;">
            <children>
                <Label style="-fx-text-fill: white; -fx-font-size: 16; -fx-font-weight: bold;" text="Evaluación" />
                <Label style="-fx-text-fill: black; -fx-font-size: 12;" text="Reportes">
                    <VBox.margin><Insets top="4.0" /></VBox.margin>
                </Label>
            </children>
        </VBox>


        <VBox layoutX="180.0" layoutY="0.0" prefWidth="570.0" spacing="10.0" style="-fx-padding: 25;">
            <children>

                <Label style="-fx-font-size: 22; -fx-font-weight: bold;" text="Evaluación de Reportes" />


                <VBox fx:id="panelError" managed="false" prefWidth="500.0" spacing="4.0" style="-fx-border-color: #8B0000; -fx-border-width: 2; -fx-background-color: #f5f5dc; -fx-padding: 10;" visible="false">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label style="-fx-text-fill: #8B0000; -fx-font-size: 14; -fx-font-weight: bold;" text="✖" />
                        <Label fx:id="etiquetaTituloError" style="-fx-font-weight: bold; -fx-text-fill: #8B0000;" text="" />
                    </HBox>
                    <Label fx:id="etiquetaMensajeError" style="-fx-text-fill: #8B0000; -fx-font-size: 11;" text="" />
                </VBox>

                <VBox fx:id="panelExito" managed="false" prefWidth="500.0" spacing="4.0" style="-fx-border-color: #2d6a2d; -fx-border-width: 2; -fx-background-color: #f0f7f0; -fx-padding: 10;" visible="false">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label style="-fx-text-fill: #2d6a2d; -fx-font-size: 14; -fx-font-weight: bold;" text="✔" />
                        <Label fx:id="etiquetaTituloExito" style="-fx-font-weight: bold; -fx-text-fill: #2d6a2d;" text="" />
                    </HBox>
                    <Label fx:id="etiquetaMensajeExito" style="-fx-text-fill: #2d6a2d; -fx-font-size: 11;" text="" />
                </VBox>


                <Label style="-fx-font-size: 13;" text="Selecciona un practicante" />
                <ComboBox fx:id="comboBoxPracticante" onAction="#seleccionarPracticante" prefWidth="500.0" promptText="-- Selecciona un practicante --" />


                <Label style="-fx-font-size: 13;" text="Reportes del practicante">
                    <VBox.margin><Insets top="10.0" /></VBox.margin>
                </Label>
                <TableView fx:id="tablaReportes" prefHeight="200.0" prefWidth="500.0">
                    <columns>
                        <TableColumn fx:id="columnaTipo" prefWidth="100.0" text="Tipo" />
                        <TableColumn fx:id="columnaDescripcion" prefWidth="200.0" text="Descripción" />
                        <TableColumn fx:id="columnaFecha" prefWidth="100.0" text="Fecha" />
                        <TableColumn fx:id="columnaEstado" prefWidth="90.0" text="Estado" />
                    </columns>
                </TableView>

                <Label style="-fx-font-size: 13;" text="Calificación">
                    <VBox.margin><Insets top="10.0" /></VBox.margin>
                </Label>
                <TextField fx:id="campoCalificacion" prefHeight="30.0" prefWidth="500.0" promptText="Ej. 90" />

                <Label style="-fx-font-size: 13;" text="Observaciones" />
                <TextField fx:id="campoObservaciones" prefHeight="30.0" prefWidth="500.0" promptText="Escribe tus observaciones" />

                <HBox spacing="15.0">
                    <VBox.margin><Insets top="10.0" /></VBox.margin>
                    <Button onAction="#botonEvaluar" prefHeight="35.0" prefWidth="140.0" style="-fx-background-color: #2c3e50; -fx-text-fill: white; -fx-background-radius: 6;" text="Evaluar" />
                    <Button onAction="#botonCancelar" prefHeight="35.0" prefWidth="140.0" style="-fx-background-color: #c0392b; -fx-text-fill: white; -fx-background-radius: 6;" text="Cancelar" />
                </HBox>

            </children>
        </VBox>


        <Button layoutX="660.0" layoutY="10.0" onAction="#botonRegresar" prefHeight="28.0" prefWidth="75.0" style="-fx-background-color: #7f8c8d; -fx-text-fill: white; -fx-background-radius: 6;" text="Regresar" />

    </children>
</AnchorPane>
