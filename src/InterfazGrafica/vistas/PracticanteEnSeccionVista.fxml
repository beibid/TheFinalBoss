<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="500.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="InterfazGrafica.PracticanteEnSeccionControlGUI">
    <children>

        <VBox layoutX="0.0" layoutY="0.0" prefHeight="500.0" prefWidth="600.0" spacing="15.0" style="-fx-padding: 30;">
            <children>

                <Label style="-fx-font-size: 22; -fx-font-weight: bold;" text="Asignar practicante a seccion" />

                <VBox fx:id="panelError" managed="false" prefWidth="500.0" spacing="4.0" style="-fx-border-color: #8B0000; -fx-border-width: 2; -fx-background-color: #f5f5dc; -fx-padding: 10;" visible="false">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label style="-fx-text-fill: #8B0000; -fx-font-size: 14; -fx-font-weight: bold;" text="✖" />
                        <Label fx:id="etiquetaTituloError" style="-fx-font-weight: bold; -fx-text-fill: #8B0000;" text="" />
                    </HBox>
                    <Label fx:id="etiquetaMensajeError" style="-fx-text-fill: #8B0000; -fx-font-size: 11;" text="" />
                </VBox>

                <VBox fx:id="panelExito" managed="false" prefWidth="500.0" spacing="4.0" style="-fx-border-color: #2d6a2d; -fx-border-width: 2; -fx-background-color: #f0f7f0; -fx-padding: 10;" visible="false">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label style="-fx-text-fill: #2d6a2d; -fx-font-size: 14; -fx-font-weight: bold;" text="✔" />
                        <Label fx:id="etiquetaTituloExito" style="-fx-font-weight: bold; -fx-text-fill: #2d6a2d;" text="" />
                    </HBox>
                    <Label fx:id="etiquetaMensajeExito" style="-fx-text-fill: #2d6a2d; -fx-font-size: 11;" text="" />
                </VBox>

                <VBox spacing="5">
                    <Label style="-fx-font-size: 13;" text="Selecciona un practicante activo" />
                    <ComboBox fx:id="comboBoxProfesores" onAction="#seleccionarProfesor" prefWidth="500.0" promptText="-- Selecciona un practicante --" />
                </VBox>

                <VBox spacing="5">
                    <Label style="-fx-font-size: 13;" text="Selecciona una seccion" />
                    <ComboBox fx:id="comboBoxMotivo" prefWidth="500.0" promptText="-- Selecciona seccion --" />
                </VBox>

                <VBox fx:id="panelDatos" managed="false" spacing="8.0" style="-fx-border-color: #cccccc; -fx-border-width: 1; -fx-padding: 15; -fx-background-color: #f9f9f9;" visible="false">
                    <Label style="-fx-font-weight: bold; -fx-font-size: 13;" text="Datos del profesor" />
                    <HBox spacing="10.0">
                        <Label style="-fx-font-weight: bold;" text="Nombre:" />
                        <Label fx:id="etiquetaNombre" text="" />
                    </HBox>
                    <HBox spacing="10.0">
                        <Label style="-fx-font-weight: bold;" text="Apellidos:" />
                        <Label fx:id="etiquetaApellidos" text="" />
                    </HBox>
                    <HBox spacing="10.0">
                        <Label style="-fx-font-weight: bold;" text="Número de personal:" />
                        <Label fx:id="etiquetaNumeroPersonal" text="" />
                    </HBox>
                </VBox>

                <HBox spacing="15.0">
                    <VBox.margin><Insets top="10.0" /></VBox.margin>
                    <Button fx:id="botonInactivar" onAction="#botonInactivar" prefHeight="35.0" prefWidth="140.0" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-background-radius: 6;" text="Asignar" />
                    <Button fx:id="botonCancelar" onAction="#botonCancelar" prefHeight="35.0" prefWidth="140.0" style="-fx-background-color: #7f8c8d; -fx-text-fill: white; -fx-background-radius: 6;" text="Cancelar" />
                </HBox>

            </children>
        </VBox>

        <Button fx:id="botonRegresar" layoutX="510.0" layoutY="10.0" onAction="#botonRegresar" prefHeight="28.0" prefWidth="75.0" style="-fx-background-color: #7f8c8d; -fx-text-fill: white; -fx-background-radius: 6;" text="Regresar" />

    </children>
</AnchorPane>
