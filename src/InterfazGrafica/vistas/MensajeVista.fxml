<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="500.0" prefWidth="700.0"
            xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="InterfazGrafica.MensajeControlGUI">
    <children>

        <VBox layoutX="0.0" layoutY="0.0" prefHeight="500.0" prefWidth="180.0"
              style="-fx-background-color: #2ecc71; -fx-padding: 15;">
            <children>
                <Label text="Mensajería" style="-fx-text-fill: white; -fx-font-size: 16; -fx-font-weight: bold;"/>
                <Label text="Nuevo mensaje" style="-fx-text-fill: black; -fx-font-size: 12;">
                    <VBox.margin><Insets top="4.0"/></VBox.margin>
                </Label>
            </children>
        </VBox>

        <VBox layoutX="180.0" layoutY="0.0" prefHeight="500.0" prefWidth="520.0"
              style="-fx-padding: 30;" spacing="10.0">
            <children>

                <Label text="Enviar Mensaje" style="-fx-font-size: 22; -fx-font-weight: bold;"/>

                <VBox fx:id="panelError" managed="false" prefWidth="450.0" spacing="4.0"
                      style="-fx-border-color: #8B0000; -fx-border-width: 2; -fx-background-color: #f5f5dc; -fx-padding: 10;"
                      visible="false">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label text="✖" style="-fx-text-fill: #8B0000; -fx-font-size: 14; -fx-font-weight: bold;"/>
                        <Label fx:id="etiquetaTituloError" style="-fx-font-weight: bold; -fx-text-fill: #8B0000;" text=""/>
                    </HBox>
                    <Label fx:id="etiquetaMensajeError" style="-fx-text-fill: #8B0000; -fx-font-size: 11;" text=""/>
                </VBox>

                <VBox fx:id="panelExito" managed="false" prefWidth="450.0" spacing="4.0"
                      style="-fx-border-color: #2d6a2d; -fx-border-width: 2; -fx-background-color: #f0f7f0; -fx-padding: 10;"
                      visible="false">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label text="✔" style="-fx-text-fill: #2d6a2d; -fx-font-size: 14; -fx-font-weight: bold;"/>
                        <Label fx:id="etiquetaTituloExito" style="-fx-font-weight: bold; -fx-text-fill: #2d6a2d;" text=""/>
                    </HBox>
                    <Label fx:id="etiquetaMensajeExito" style="-fx-text-fill: #2d6a2d; -fx-font-size: 11;" text=""/>
                </VBox>

                <Label text="Destinatario" style="-fx-font-size: 13;">
                    <VBox.margin><Insets top="10.0"/></VBox.margin>
                </Label>
                <ComboBox fx:id="comboBoxDestinatario" prefWidth="450.0"
                          promptText="-- Selecciona un destinatario --"/>

                <Label text="Mensaje" style="-fx-font-size: 13;"/>
                <TextArea fx:id="areaTextoMensaje" prefHeight="120.0" prefWidth="450.0"
                          promptText="Escribe tu mensaje aquí..." wrapText="true"/>

                <HBox spacing="15.0">
                    <VBox.margin><Insets top="20.0"/></VBox.margin>
                    <Button onAction="#botonEnviar" prefWidth="140.0" prefHeight="35.0"
                            text="Enviar"
                            style="-fx-background-color: #2c3e50; -fx-text-fill: white; -fx-background-radius: 6;"/>
                    <Button onAction="#botonCancelar" prefWidth="140.0" prefHeight="35.0"
                            text="Cancelar"
                            style="-fx-background-color: #c0392b; -fx-text-fill: white; -fx-background-radius: 6;"/>
                </HBox>

            </children>
        </VBox>

        <Button layoutX="610.0" layoutY="10.0" onAction="#botonRegresar"
                prefHeight="28.0" prefWidth="75.0" text="Regresar"
                style="-fx-background-color: #7f8c8d; -fx-text-fill: white; -fx-background-radius: 6;"/>

    </children>
</AnchorPane>