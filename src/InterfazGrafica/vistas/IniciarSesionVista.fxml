<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="500.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="InterfazGrafica.IniciarSesionControlador">
    <children>
        <Label layoutX="170.0" layoutY="30.0" text="Iniciar Sesión">
            <font>
                <Font size="24.0" />
            </font>
        </Label>

        <VBox fx:id="panelError" layoutX="100.0" layoutY="70.0" maxWidth="300.0" prefWidth="300.0" spacing="4.0" style="-fx-border-color: #8B0000; -fx-border-width: 2; -fx-background-color: #f5f5dc; -fx-padding: 10;" visible="false">
            <HBox alignment="CENTER_LEFT" spacing="8">
                <Label style="-fx-text-fill: #8B0000; -fx-font-size: 16; -fx-font-weight: bold;" text="✖" />
                <Label fx:id="etiquetaTituloError" style="-fx-font-weight: bold; -fx-text-fill: #8B0000;" text="" />
            </HBox>
            <Label fx:id="etiquetaMensajeError" style="-fx-text-fill: #8B0000; -fx-font-size: 11;" text="" wrapText="true" />
        </VBox>

        <Label layoutX="100.0" layoutY="180.0" text="Usuario" />
        <TextField fx:id="campoTextoIdentificador" layoutX="100.0" layoutY="205.0" prefHeight="27.0" prefWidth="300.0" promptText="Correo Electronico" />

        <Label layoutX="100.0" layoutY="250.0" text="Contraseña" />
        <PasswordField fx:id="campoTextoContrasena" layoutX="100.0" layoutY="275.0" prefHeight="27.0" prefWidth="300.0" promptText="Contraseña" />

        <Button fx:id="botonIniciarSesion" layoutX="100.0" layoutY="330.0" onAction="#botonIniciarSesion" prefWidth="300.0" text="Iniciar Sesión" />
    </children>
</AnchorPane>