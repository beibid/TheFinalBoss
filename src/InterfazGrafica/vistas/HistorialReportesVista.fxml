<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="600.0" prefWidth="750.0"
            xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="InterfazGrafica.HistorialReportesPracticanteControlador">
    <children>

        <VBox layoutX="0.0" layoutY="0.0" prefHeight="600.0" prefWidth="180.0"
              style="-fx-background-color: #2ecc71; -fx-padding: 15;">
            <children>
                <Label text="Historial" style="-fx-text-fill: white; -fx-font-size: 16; -fx-font-weight: bold;"/>
                <Label text="Reportes" style="-fx-text-fill: black; -fx-font-size: 12;">
                    <VBox.margin><Insets top="4.0"/></VBox.margin>
                </Label>
            </children>
        </VBox>

        <VBox layoutX="180.0" layoutY="0.0" prefWidth="570.0" spacing="8.0"
              style="-fx-padding: 25;">
            <children>

                <Label style="-fx-font-size: 22; -fx-font-weight: bold;" text="Historial de Reportes"/>

                <VBox fx:id="panelError" managed="false" prefWidth="500.0" spacing="4.0"
                      style="-fx-border-color: #8B0000; -fx-border-width: 2; -fx-background-color: #f5f5dc; -fx-padding: 10;"
                      visible="false">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label style="-fx-text-fill: #8B0000; -fx-font-size: 14; -fx-font-weight: bold;" text="✖"/>
                        <Label fx:id="etiquetaTituloError" style="-fx-font-weight: bold; -fx-text-fill: #8B0000;" text=""/>
                    </HBox>
                    <Label fx:id="etiquetaMensajeError" style="-fx-text-fill: #8B0000; -fx-font-size: 11;" text=""/>
                </VBox>

                <TableView fx:id="tablaReportes" prefHeight="450.0" prefWidth="500.0">
                    <columns>
                        <TableColumn fx:id="columnaTipo" text="Tipo" prefWidth="80.0"/>
                        <TableColumn fx:id="columnaDescripcion" text="Descripción" prefWidth="150.0"/>
                        <TableColumn fx:id="columnaFecha" text="Fecha" prefWidth="90.0"/>
                        <TableColumn fx:id="columnaCalificacion" text="Calificación" prefWidth="90.0"/>
                        <TableColumn fx:id="columnaObservaciones" text="Observaciones" prefWidth="150.0"/>
                        <TableColumn fx:id="columnaEstado" text="Estado" prefWidth="90.0"/>
                    </columns>
                </TableView>

            </children>
        </VBox>

        <Button layoutX="660.0" layoutY="10.0" onAction="#botonRegresar"
                prefHeight="28.0" prefWidth="75.0"
                style="-fx-background-color: #7f8c8d; -fx-text-fill: white; -fx-background-radius: 6;"
                text="Regresar"/>

    </children>
</AnchorPane>