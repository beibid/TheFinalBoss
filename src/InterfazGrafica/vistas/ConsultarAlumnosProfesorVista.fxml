<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="680.0" prefWidth="850.0"
            xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="InterfazGrafica.ConsultarAlumnosProfesorControlador">
    <children>

        <VBox layoutX="0.0" layoutY="0.0" prefHeight="680.0" prefWidth="180.0"
              style="-fx-background-color: #2ecc71; -fx-padding: 15;">
            <children>
                <Label text="Mis" style="-fx-text-fill: white; -fx-font-size: 16; -fx-font-weight: bold;"/>
                <Label text="Alumnos" style="-fx-text-fill: black; -fx-font-size: 12;">
                    <VBox.margin><Insets top="4.0"/></VBox.margin>
                </Label>
            </children>
        </VBox>

        <ScrollPane layoutX="180.0" layoutY="0.0" prefHeight="680.0" prefWidth="670.0" fitToWidth="true">
            <content>
                <VBox prefWidth="650.0" spacing="10.0" style="-fx-padding: 25;">
                    <children>

                        <Label text="Consultar Alumnos" style="-fx-font-size: 22; -fx-font-weight: bold;"/>

                        <VBox fx:id="panelError" managed="false" prefWidth="600.0" spacing="4.0"
                              style="-fx-border-color: #8B0000; -fx-border-width: 2; -fx-background-color: #f5f5dc; -fx-padding: 10;"
                              visible="false">
                            <HBox alignment="CENTER_LEFT" spacing="8">
                                <Label text="✖" style="-fx-text-fill: #8B0000; -fx-font-size: 14; -fx-font-weight: bold;"/>
                                <Label fx:id="etiquetaTituloError" style="-fx-font-weight: bold; -fx-text-fill: #8B0000;" text=""/>
                            </HBox>
                            <Label fx:id="etiquetaMensajeError" style="-fx-text-fill: #8B0000; -fx-font-size: 11;" text=""/>
                        </VBox>

                        <HBox spacing="10.0" alignment="CENTER_LEFT">
                            <Label text="Filtrar por:" style="-fx-font-size: 13; -fx-font-weight: bold;"/>
                            <ComboBox fx:id="comboFiltro" prefWidth="200.0"/>
                        </HBox>

                        <TableView fx:id="tablaAlumnos" prefHeight="200.0" prefWidth="600.0">
                            <columns>
                                <TableColumn fx:id="columnaMatricula" text="Matrícula" prefWidth="100.0"/>
                                <TableColumn fx:id="columnaNombre" text="Nombre" prefWidth="150.0"/>
                                <TableColumn fx:id="columnaApellidos" text="Apellidos" prefWidth="150.0"/>
                                <TableColumn fx:id="columnaCorreo" text="Correo" prefWidth="180.0"/>
                            </columns>
                        </TableView>

                        <Separator><VBox.margin><Insets bottom="5.0" top="5.0"/></VBox.margin></Separator>

                        <VBox fx:id="panelDetalle" spacing="8.0"
                              style="-fx-border-color: #cccccc; -fx-border-width: 1; -fx-padding: 15; -fx-background-color: #fafafa;">
                            <Label text="Detalle del alumno seleccionado"
                                   style="-fx-font-size: 14; -fx-font-weight: bold;"/>
                            <HBox spacing="10.0">
                                <Label text="Proyecto:" style="-fx-font-weight: bold;"/>
                                <Label fx:id="etiquetaProyecto" text=""/>
                            </HBox>
                            <HBox spacing="10.0">
                                <Label text="Horas acumuladas:" style="-fx-font-weight: bold;"/>
                                <Label fx:id="etiquetaHoras" text=""/>
                            </HBox>
                            <HBox spacing="10.0">
                                <Label text="Reportes:" style="-fx-font-weight: bold;"/>
                                <Label fx:id="etiquetaReportes" text=""/>
                            </HBox>

                            <Separator><VBox.margin><Insets bottom="3.0" top="3.0"/></VBox.margin></Separator>

                            <Label text="Actividades registradas"
                                   style="-fx-font-size: 13; -fx-font-weight: bold;"/>
                            <TableView fx:id="tablaActividades" prefHeight="180.0" prefWidth="600.0">
                                <columns>
                                    <TableColumn fx:id="columnaTituloActividad" text="Actividad" prefWidth="200.0"/>
                                    <TableColumn fx:id="columnaFechaInicio" text="Fecha inicio" prefWidth="120.0"/>
                                    <TableColumn fx:id="columnaFechaFin" text="Fecha fin" prefWidth="120.0"/>
                                    <TableColumn fx:id="columnaHoras" text="Horas" prefWidth="80.0"/>
                                </columns>
                            </TableView>
                        </VBox>

                    </children>
                </VBox>
            </content>
        </ScrollPane>

        <Button layoutX="760.0" layoutY="10.0" onAction="#botonRegresar"
                prefHeight="28.0" prefWidth="75.0" text="Regresar"
                style="-fx-background-color: #7f8c8d; -fx-text-fill: white; -fx-background-radius: 6;"/>

    </children>
</AnchorPane>