<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="600.0" prefWidth="750.0"
            xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="InterfazGrafica.ModificarCoordinadorControlador">
    <children>

        <VBox layoutX="0.0" layoutY="0.0" prefHeight="600.0" prefWidth="180.0"
              style="-fx-background-color: #2ecc71; -fx-padding: 15;">
            <children>
                <Label text="Modificar" style="-fx-text-fill: white; -fx-font-size: 16; -fx-font-weight: bold;"/>
                <Label text="Coordinador" style="-fx-text-fill: black; -fx-font-size: 12;">
                    <VBox.margin><Insets top="4.0"/></VBox.margin>
                </Label>
            </children>
        </VBox>

        <ScrollPane layoutX="180.0" layoutY="0.0" prefHeight="600.0" prefWidth="570.0" fitToWidth="true">
            <content>
                <VBox prefWidth="550.0" spacing="8.0" style="-fx-padding: 25;">
                    <children>

                        <Label text="Modificar Coordinador" style="-fx-font-size: 22; -fx-font-weight: bold;"/>

                        <VBox fx:id="panelError" managed="false" prefWidth="500.0" spacing="4.0"
                              style="-fx-border-color: #8B0000; -fx-border-width: 2; -fx-background-color: #f5f5dc; -fx-padding: 10;"
                              visible="false">
                            <HBox alignment="CENTER_LEFT" spacing="8">
                                <Label text="✖" style="-fx-text-fill: #8B0000; -fx-font-size: 14; -fx-font-weight: bold;"/>
                                <Label fx:id="etiquetaTituloError" style="-fx-font-weight: bold; -fx-text-fill: #8B0000;" text=""/>
                            </HBox>
                            <Label fx:id="etiquetaMensajeError" style="-fx-text-fill: #8B0000; -fx-font-size: 11;" text=""/>
                        </VBox>

                        <VBox fx:id="panelExito" managed="false" prefWidth="500.0" spacing="4.0"
                              style="-fx-border-color: #2d6a2d; -fx-border-width: 2; -fx-background-color: #f0f7f0; -fx-padding: 10;"
                              visible="false">
                            <HBox alignment="CENTER_LEFT" spacing="8">
                                <Label text="✔" style="-fx-text-fill: #2d6a2d; -fx-font-size: 14; -fx-font-weight: bold;"/>
                                <Label fx:id="etiquetaTituloExito" style="-fx-font-weight: bold; -fx-text-fill: #2d6a2d;" text=""/>
                            </HBox>
                            <Label fx:id="etiquetaMensajeExito" style="-fx-text-fill: #2d6a2d; -fx-font-size: 11;" text=""/>
                        </VBox>

                        <Label text="Selecciona un coordinador" style="-fx-font-size: 13;"/>
                        <ComboBox fx:id="comboBoxCoordinadores" onAction="#seleccionarCoordinador"
                                  prefWidth="500.0" promptText="-- Selecciona un coordinador --"/>

                        <VBox fx:id="panelFormulario" managed="false" visible="false" spacing="8.0">
                            <children>

                                <Label text="Nombre(s)" style="-fx-font-size: 13;">
                                    <VBox.margin><Insets top="5.0"/></VBox.margin>
                                </Label>
                                <TextField fx:id="campoNombre" prefHeight="30.0" prefWidth="500.0"
                                           promptText="Ej. Juan Carlos"/>

                                <Label text="Apellidos" style="-fx-font-size: 13;"/>
                                <TextField fx:id="campoApellidos" prefHeight="30.0" prefWidth="500.0"
                                           promptText="Ej. García López"/>

                                <Label text="Correo" style="-fx-font-size: 13;"/>
                                <TextField fx:id="campoCorreo" prefHeight="30.0" prefWidth="500.0"
                                           promptText="Ej. juan@uv.mx"/>

                                <HBox spacing="15.0">
                                    <VBox.margin><Insets top="10.0"/></VBox.margin>
                                    <Button fx:id="botonGuardar" onAction="#botonGuardar"
                                            prefHeight="35.0" prefWidth="140.0" text="Guardar cambios"
                                            style="-fx-background-color: #2c3e50; -fx-text-fill: white; -fx-background-radius: 6;"/>
                                    <Button fx:id="botonCancelar" onAction="#botonCancelar"
                                            prefHeight="35.0" prefWidth="140.0" text="Cancelar"
                                            style="-fx-background-color: #c0392b; -fx-text-fill: white; -fx-background-radius: 6;"/>
                                </HBox>

                            </children>
                        </VBox>

                    </children>
                </VBox>
            </content>
        </ScrollPane>

        <Button fx:id="botonRegresar" layoutX="660.0" layoutY="10.0" onAction="#botonRegresar"
                prefHeight="28.0" prefWidth="75.0" text="Regresar"
                style="-fx-background-color: #7f8c8d; -fx-text-fill: white; -fx-background-radius: 6;"/>

    </children>
</AnchorPane>