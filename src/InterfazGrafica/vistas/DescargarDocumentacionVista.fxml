<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="500.0" prefWidth="600.0"
            xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="InterfazGrafica.DescargarDocumentacionControlador">
    <children>
        <VBox layoutX="0.0" layoutY="0.0" prefHeight="500.0" prefWidth="600.0"
              style="-fx-padding: 30;" spacing="10.0">
            <children>

                <Label style="-fx-font-size: 18; -fx-font-weight: bold;"
                       text="Documentación disponible">
                    <VBox.margin><Insets bottom="10.0"/></VBox.margin>
                </Label>

                <VBox fx:id="panelError" managed="false" prefWidth="500.0" spacing="4.0"
                      style="-fx-border-color: #8B0000; -fx-border-width: 2; -fx-background-color: #f5f5dc; -fx-padding: 10;"
                      visible="false">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label style="-fx-text-fill: #8B0000; -fx-font-size: 14; -fx-font-weight: bold;" text="✖"/>
                        <Label fx:id="etiquetaTituloError" style="-fx-font-weight: bold; -fx-text-fill: #8B0000;" text=""/>
                    </HBox>
                    <Label fx:id="etiquetaMensajeError" style="-fx-text-fill: #8B0000; -fx-font-size: 11;" text=""/>
                </VBox>

                <VBox fx:id="panelExito" managed="false" prefWidth="500.0" spacing="4.0"
                      style="-fx-border-color: #2d6a2d; -fx-border-width: 2; -fx-background-color: #f0f7f0; -fx-padding: 10;"
                      visible="false">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label style="-fx-text-fill: #2d6a2d; -fx-font-size: 14; -fx-font-weight: bold;" text="✔"/>
                        <Label fx:id="etiquetaTituloExito" style="-fx-font-weight: bold; -fx-text-fill: #2d6a2d;" text=""/>
                    </HBox>
                    <Label fx:id="etiquetaMensajeExito" style="-fx-text-fill: #2d6a2d; -fx-font-size: 11;" text=""/>
                </VBox>

                <TableView fx:id="tablaDocumentos" prefHeight="280.0" prefWidth="540.0">
                    <columns>
                        <TableColumn fx:id="columnaDocumento" prefWidth="420.0" text="Documento"/>
                        <TableColumn fx:id="columnaAccion" prefWidth="118.0" text="Acción"/>
                    </columns>
                </TableView>

                <Label fx:id="etiquetaMensaje" style="-fx-font-size: 12;" text="">
                    <VBox.margin><Insets top="5.0"/></VBox.margin>
                </Label>

                <Button onAction="#cerrar"
                        style="-fx-background-color: #c0392b; -fx-text-fill: white;"
                        text="Cerrar">
                    <VBox.margin><Insets top="10.0"/></VBox.margin>
                </Button>

            </children>
        </VBox>
    </children>
</AnchorPane>