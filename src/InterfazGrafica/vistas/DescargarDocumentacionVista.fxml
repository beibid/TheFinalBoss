<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="InterfazGrafica.DescargarDocumentacionControlador">
    <children>
        <VBox layoutX="0.0" layoutY="0.0" prefHeight="400.0" prefWidth="600.0" style="-fx-padding: 30;">
            <children>
                <Label style="-fx-font-size: 18; -fx-font-weight: bold;" text="Documentación disponible">
                    <VBox.margin><Insets bottom="20.0" /></VBox.margin>
                </Label>

                <TableView fx:id="tablaDocumentos" prefHeight="280.0" prefWidth="540.0">
                    <columns>
                        <TableColumn fx:id="columnaDocumento" prefWidth="420.0" text="Documento" />
                        <TableColumn fx:id="columnaAccion" prefWidth="118.0" text="Acción" />
                    </columns>
                </TableView>

                <Label fx:id="etiquetaMensaje" style="-fx-font-size: 12;" text="">
                    <VBox.margin><Insets top="10.0" /></VBox.margin>
                </Label>

                <Button onAction="#cerrar" style="-fx-background-color: #c0392b; -fx-text-fill: white;" text="Cerrar">
                    <VBox.margin><Insets top="15.0" /></VBox.margin>
                </Button>
            </children>
        </VBox>
    </children>
</AnchorPane>