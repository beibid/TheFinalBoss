<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="600.0" prefWidth="750.0"
            xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="InterfazGrafica.MenuCoordinadorControlador">
    <children>

        <ScrollPane layoutX="0.0" layoutY="0.0" prefHeight="600.0" prefWidth="200.0"
                    hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" fitToWidth="true"
                    style="-fx-background: #2ecc71; -fx-background-color: #2ecc71;">
            <content>
                <VBox prefWidth="183.0" style="-fx-background-color: #2ecc71; -fx-padding: 15;">
                    <children>
                        <Label text="Coordinador" style="-fx-text-fill: white; -fx-font-size: 16; -fx-font-weight: bold;"/>
                        <Label fx:id="lblNombre" text="" style="-fx-text-fill: white; -fx-font-size: 12;">
                            <VBox.margin><Insets top="4.0"/></VBox.margin>
                        </Label>
                        <Label fx:id="lblRol" text="" style="-fx-text-fill: white; -fx-font-size: 11; -fx-background-color: #27ae60; -fx-padding: 3 8 3 8; -fx-background-radius: 10;">
                            <VBox.margin><Insets top="5.0" bottom="10.0"/></VBox.margin>
                        </Label>

                        <Separator><VBox.margin><Insets top="5.0" bottom="10.0"/></VBox.margin></Separator>

                        <Label text="Alumnos" style="-fx-text-fill: white; -fx-font-size: 11;"/>
                        <Button onAction="#abrirConsultarAlumnos" prefWidth="170.0"
                                style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER-LEFT;"
                                text="Consultar alumnos">
                            <VBox.margin><Insets top="5.0"/></VBox.margin>
                        </Button>

                        <Separator><VBox.margin><Insets top="10.0" bottom="10.0"/></VBox.margin></Separator>

                        <Label text="Practicante" style="-fx-text-fill: white; -fx-font-size: 11;"/>
                        <Button onAction="#abrirRegistrarPracticante" prefWidth="170.0"
                                style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER-LEFT;"
                                text="Registrar">
                            <VBox.margin><Insets top="5.0"/></VBox.margin>
                        </Button>
                        <Button onAction="#abrirInactivarPracticante" prefWidth="170.0"
                                style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER-LEFT;"
                                text="Inactivar">
                            <VBox.margin><Insets top="3.0"/></VBox.margin>
                        </Button>
                        <Button onAction="#abrirAsignarPracticanteEnSeccion" prefWidth="170.0"
                                style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER-LEFT;"
                                text="Asignar a seccion">
                            <VBox.margin><Insets top="3.0"/></VBox.margin>
                        </Button>
                        <Button onAction="#abrirAsignarProyectoAlPracticante" prefWidth="170.0"
                                style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER-LEFT;"
                                text="Asignarle proyecto">
                            <VBox.margin><Insets top="3.0"/></VBox.margin>
                        </Button>
                        <Button onAction="#abrirModificarPracticante" prefWidth="170.0"
                                style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER-LEFT;"
                                text="Modificar">
                            <VBox.margin><Insets top="3.0"/></VBox.margin>
                        </Button>

                        <Separator><VBox.margin><Insets top="10.0" bottom="10.0"/></VBox.margin></Separator>

                        <Label text="Profesor" style="-fx-text-fill: white; -fx-font-size: 11;"/>
                        <Button onAction="#abrirRegistrarProfesor" prefWidth="170.0"
                                style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER-LEFT;"
                                text="Registrar">
                            <VBox.margin><Insets top="5.0"/></VBox.margin>
                        </Button>
                        <Button onAction="#abrirInactivarProfesor" prefWidth="170.0"
                                style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER-LEFT;"
                                text="Inactivar">
                            <VBox.margin><Insets top="3.0"/></VBox.margin>
                        </Button>
                        <Button onAction="#abrirModificarProfesor" prefWidth="170.0"
                                style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER-LEFT;"
                                text="Modificar profesor">
                            <VBox.margin><Insets top="3.0"/></VBox.margin>
                        </Button>

                        <Separator><VBox.margin><Insets top="10.0" bottom="10.0"/></VBox.margin></Separator>

                        <Label text="Proyecto" style="-fx-text-fill: white; -fx-font-size: 11;"/>
                        <Button onAction="#abrirRegistrarProyecto" prefWidth="170.0"
                                style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER-LEFT;"
                                text="Registrar">
                            <VBox.margin><Insets top="5.0"/></VBox.margin>
                        </Button>
                        <Button onAction="#abrirInactivarProyecto" prefWidth="170.0"
                                style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER-LEFT;"
                                text="Inactivar">
                            <VBox.margin><Insets top="3.0"/></VBox.margin>
                        </Button>
                        <Button onAction="#abrirModificarProyecto" prefWidth="170.0"
                                style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER-LEFT;"
                                text="Modificar">
                            <VBox.margin><Insets top="3.0"/></VBox.margin>
                        </Button>

                        <Separator><VBox.margin><Insets top="10.0" bottom="10.0"/></VBox.margin></Separator>

                        <Label text="Organizacion Vinculada" style="-fx-text-fill: white; -fx-font-size: 11;"/>
                        <Button onAction="#abrirRegistrarOrganizacion" prefWidth="170.0"
                                style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER-LEFT;"
                                text="Registrar">
                            <VBox.margin><Insets top="5.0"/></VBox.margin>
                        </Button>
                        <Button onAction="#abrirInactivarOrganizacion" prefWidth="170.0"
                                style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER-LEFT;"
                                text="Inactivar">
                            <VBox.margin><Insets top="3.0"/></VBox.margin>
                        </Button>
                        <Button onAction="#abrirModificarOrganizacion" prefWidth="170.0"
                                style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER-LEFT;"
                                text="Modificar">
                            <VBox.margin><Insets top="3.0"/></VBox.margin>
                        </Button>

                        <Separator><VBox.margin><Insets top="10.0" bottom="10.0"/></VBox.margin></Separator>

                        <Label text="Periodo" style="-fx-text-fill: white; -fx-font-size: 11;"/>
                        <Button onAction="#abrirRegistrarPeriodo" prefWidth="170.0"
                                style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER-LEFT;"
                                text="Registrar">
                            <VBox.margin><Insets top="5.0"/></VBox.margin>
                        </Button>
                        <Button onAction="#abrirCerrarPeriodo" prefWidth="170.0"
                                style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER-LEFT;"
                                text="Cerrar">
                            <VBox.margin><Insets top="3.0"/></VBox.margin>
                        </Button>

                        <Separator><VBox.margin><Insets top="10.0" bottom="10.0"/></VBox.margin></Separator>

                        <Label text="Seccion" style="-fx-text-fill: white; -fx-font-size: 11;"/>
                        <Button onAction="#abrirRegistrarSeccion" prefWidth="170.0"
                                style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER-LEFT;"
                                text="Registrar">
                            <VBox.margin><Insets top="5.0"/></VBox.margin>
                        </Button>

                        <Separator><VBox.margin><Insets top="10.0" bottom="10.0"/></VBox.margin></Separator>

                        <Button onAction="#cerrarSesion" prefWidth="170.0"
                                style="-fx-background-color: #c0392b; -fx-text-fill: white;"
                                text="Cerrar Sesion">
                            <VBox.margin><Insets top="5.0"/></VBox.margin>
                        </Button>
                    </children>
                </VBox>
            </content>
        </ScrollPane>

        <VBox alignment="CENTER" layoutX="200.0" layoutY="0.0" prefHeight="600.0" prefWidth="550.0"
              style="-fx-padding: 30;">
            <children>
                <Label fx:id="lblBienvenida" text="" style="-fx-font-size: 22; -fx-font-weight: bold;"/>
                <Label text="Selecciona una opcion del menu" style="-fx-font-size: 13; -fx-text-fill: #666666;">
                    <VBox.margin><Insets top="8.0"/></VBox.margin>
                </Label>
            </children>
        </VBox>

    </children>
</AnchorPane>