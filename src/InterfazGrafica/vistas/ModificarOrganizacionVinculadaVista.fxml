<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="InterfazGrafica.ModificarOrganizacionVinculadaControlador"
            prefHeight="550.0" prefWidth="700.0">
    <children>

        <VBox layoutX="0.0" layoutY="0.0" prefHeight="550.0" prefWidth="180.0"
              style="-fx-background-color: #2ecc71; -fx-padding: 15;">
            <children>
                <Label style="-fx-text-fill: white; -fx-font-size: 16; -fx-font-weight: bold;" text="Modificar" />
                <Label style="-fx-text-fill: black; -fx-font-size: 12;" text="Organización Vinculada">
                    <VBox.margin><Insets top="4.0"/></VBox.margin>
                </Label>
            </children>
        </VBox>

        <VBox layoutX="180.0" layoutY="0.0" prefHeight="550.0" prefWidth="520.0"
              spacing="10.0" style="-fx-padding: 30;">
            <children>

                <Label style="-fx-font-size: 22; -fx-font-weight: bold;" text="Modificar Organización Vinculada" />

                <VBox fx:id="panelError" managed="false" prefWidth="450.0" spacing="4.0"
                      style="-fx-border-color: #8B0000; -fx-border-width: 2; -fx-background-color: #f5f5dc; -fx-padding: 10;"
                      visible="false">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label style="-fx-text-fill: #8B0000; -fx-font-size: 14; -fx-font-weight: bold;" text="✖" />
                        <Label fx:id="etiquetaTituloError" style="-fx-font-weight: bold; -fx-text-fill: #8B0000;" text="" />
                    </HBox>
                    <Label fx:id="etiquetaMensajeError" style="-fx-text-fill: #8B0000; -fx-font-size: 11;" text="" />
                </VBox>

                <VBox fx:id="panelExito" managed="false" prefWidth="450.0" spacing="4.0"
                      style="-fx-border-color: #2d6a2d; -fx-border-width: 2; -fx-background-color: #f0f7f0; -fx-padding: 10;"
                      visible="false">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label style="-fx-text-fill: #2d6a2d; -fx-font-size: 14; -fx-font-weight: bold;" text="✔" />
                        <Label fx:id="etiquetaTituloExito" style="-fx-font-weight: bold; -fx-text-fill: #2d6a2d;" text="" />
                    </HBox>
                    <Label fx:id="etiquetaMensajeExito" style="-fx-text-fill: #2d6a2d; -fx-font-size: 11;" text="" />
                </VBox>

                <Label style="-fx-font-size: 13;" text="Selecciona una organización">
                    <VBox.margin><Insets top="10.0"/></VBox.margin>
                </Label>
                <ComboBox fx:id="comboBoxOrganizacion" onAction="#seleccionarOrganizacion"
                          prefHeight="30.0" prefWidth="450.0" />

                <VBox fx:id="panelFormulario" managed="false" spacing="8.0" visible="false">
                    <VBox.margin><Insets top="10.0"/></VBox.margin>

                    <Label style="-fx-font-size: 13;" text="Nombre de la organización" />
                    <TextField fx:id="campoNombre" prefHeight="30.0" prefWidth="450.0" />

                    <Label style="-fx-font-size: 13;" text="Dirección" />
                    <TextField fx:id="campoDireccion" prefHeight="30.0" prefWidth="450.0" />

                    <Label style="-fx-font-size: 13;" text="Teléfono" />
                    <TextField fx:id="campoTelefono" prefHeight="30.0" prefWidth="450.0"
                               promptText="Ej. 2281234567" />

                    <Label style="-fx-font-size: 13;" text="Correo electrónico" />
                    <TextField fx:id="campoCorreo" prefHeight="30.0" prefWidth="450.0"
                               promptText="Ej. contacto@empresa.com" />

                    <Label style="-fx-font-size: 13;" text="Sector" />
                    <TextField fx:id="campoSector" prefHeight="30.0" prefWidth="450.0"
                               promptText="Ej. Tecnología" />

                    <HBox spacing="15.0">
                        <VBox.margin><Insets top="15.0"/></VBox.margin>
                        <Button fx:id="botonGuardar" onAction="#botonGuardar" prefHeight="35.0" prefWidth="140.0"
                                style="-fx-background-color: #2c3e50; -fx-text-fill: white; -fx-background-radius: 6;"
                                text="Guardar" />
                        <Button fx:id="botonCancelar" onAction="#botonCancelar" prefHeight="35.0" prefWidth="140.0"
                                style="-fx-background-color: #c0392b; -fx-text-fill: white; -fx-background-radius: 6;"
                                text="Cancelar" />
                    </HBox>
                </VBox>

            </children>
        </VBox>

        <Button fx:id="botonRegresar" layoutX="610.0" layoutY="10.0" onAction="#botonRegresar"
                prefHeight="28.0" prefWidth="75.0"
                style="-fx-background-color: #7f8c8d; -fx-text-fill: white; -fx-background-radius: 6;"
                text="Regresar" />


    </children>
</AnchorPane>