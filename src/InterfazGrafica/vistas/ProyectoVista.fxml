<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="650.0" prefWidth="750.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="InterfazGrafica.ProyectoControlGUI">
    <children>

        <!-- Sidebar -->
        <VBox layoutX="0.0" layoutY="0.0" prefHeight="720.0" prefWidth="180.0" style="-fx-background-color: #3a3a3a; -fx-padding: 15;">
            <children>
                <Label style="-fx-text-fill: white; -fx-font-size: 16; -fx-font-weight: bold;" text="Registro" />
                <Label style="-fx-text-fill: #aaaaaa; -fx-font-size: 12;" text="Proyecto">
                    <VBox.margin><Insets top="4.0" /></VBox.margin>
                </Label>
            </children>
        </VBox>

        <!-- Contenido principal -->
        <VBox layoutX="180.0" layoutY="0.0" prefWidth="570.0" spacing="8.0" style="-fx-padding: 25;">
            <children>

                <Label style="-fx-font-size: 22; -fx-font-weight: bold;" text="Registro de Proyecto" />

                <!-- Panel error -->
                <VBox fx:id="panelError" managed="false" prefWidth="500.0" spacing="4.0" style="-fx-border-color: #8B0000; -fx-border-width: 2; -fx-background-color: #f5f5dc; -fx-padding: 10;" visible="false">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label style="-fx-text-fill: #8B0000; -fx-font-size: 14; -fx-font-weight: bold;" text="✖" />
                        <Label fx:id="lblTituloError" style="-fx-font-weight: bold; -fx-text-fill: #8B0000;" text="" />
                    </HBox>
                    <Label fx:id="lblMensajeError" style="-fx-text-fill: #8B0000; -fx-font-size: 11;" text="" />
                </VBox>

                <!-- Panel exito -->
                <VBox fx:id="panelExito" managed="false" prefWidth="500.0" spacing="4.0" style="-fx-border-color: #2d6a2d; -fx-border-width: 2; -fx-background-color: #f0f7f0; -fx-padding: 10;" visible="false">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label style="-fx-text-fill: #2d6a2d; -fx-font-size: 14; -fx-font-weight: bold;" text="✔" />
                        <Label fx:id="lblTituloExito" style="-fx-font-weight: bold; -fx-text-fill: #2d6a2d;" text="" />
                    </HBox>
                    <Label fx:id="lblMensajeExito" style="-fx-text-fill: #2d6a2d; -fx-font-size: 11;" text="" />
                </VBox>

                <!-- Campos -->
                <Label style="-fx-font-size: 13;" text="Nombre del proyecto" />
                <TextField fx:id="txtNombreProyecto" prefHeight="30.0" prefWidth="500.0" promptText="Ej. Sistema de inventario" />

                <Label style="-fx-font-size: 13;" text="Descripción" />
                <TextField fx:id="txtDescripcion" prefHeight="30.0" prefWidth="500.0" promptText="Ej. Sistema para gestionar inventario" />

                <Label style="-fx-font-size: 13;" text="Responsable del proyecto" />
                <TextField fx:id="txtResponsable" prefHeight="30.0" prefWidth="500.0" promptText="Ej. Juan Pérez" />

                <Label style="-fx-font-size: 13;" text="Nombre de la empresa" />
                <TextField fx:id="txtNombreEmpresa" prefHeight="30.0" prefWidth="500.0" promptText="Ej. Tech Solutions" />

                <Label style="-fx-font-size: 13;" text="Sector de la empresa" />
                <TextField fx:id="txtSectorEmpresa" prefHeight="30.0" prefWidth="500.0" promptText="Ej. Tecnología" />

                <Label style="-fx-font-size: 13;" text="Dirección de la empresa" />
                <TextField fx:id="txtDireccionEmpresa" prefHeight="30.0" prefWidth="500.0" promptText="Ej. Av. Principal 123" />

                <Label style="-fx-font-size: 13;" text="Practicante" />
                <ComboBox fx:id="cmbPracticante" prefWidth="500.0" promptText="-- Selecciona un practicante --" />

                <Label style="-fx-font-size: 13;" text="Coordinador" />
                <ComboBox fx:id="cmbCoordinador" prefWidth="500.0" promptText="-- Selecciona un coordinador --" />

                <Label style="-fx-font-size: 13;" text="Organización" />
                <ComboBox fx:id="cmbOrganizacion" prefWidth="500.0" promptText="-- Selecciona una organización --" />

                <!-- Botones -->
                <HBox spacing="15.0">
                    <VBox.margin><Insets top="10.0" /></VBox.margin>
                    <Button fx:id="btnRegistrar" onAction="#botonRegistrar" prefHeight="35.0" prefWidth="140.0" style="-fx-background-color: #2c3e50; -fx-text-fill: white; -fx-background-radius: 6;" text="Registrar" />
                    <Button fx:id="btnCancelar" onAction="#botonCancelar" prefHeight="35.0" prefWidth="140.0" style="-fx-background-color: #c0392b; -fx-text-fill: white; -fx-background-radius: 6;" text="Cancelar" />
                </HBox>

            </children>
        </VBox>

        <!-- Boton regresar -->
        <Button layoutX="660.0" layoutY="10.0" onAction="#botonRegresar" prefHeight="28.0" prefWidth="75.0" style="-fx-background-color: #7f8c8d; -fx-text-fill: white; -fx-background-radius: 6;" text="Regresar" />

    </children>
</AnchorPane>
