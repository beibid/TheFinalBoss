<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="550.0" prefWidth="700.0"
            xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="InterfazGrafica.RegistrarActividadControlador">
    <children>

        <VBox layoutX="0.0" layoutY="0.0" prefHeight="550.0" prefWidth="180.0"
              style="-fx-background-color: #2ecc71; -fx-padding: 15;">
            <children>
                <Label style="-fx-text-fill: white; -fx-font-size: 16; -fx-font-weight: bold;" text="Registrar" />
                <Label style="-fx-text-fill: black; -fx-font-size: 12;" text="Actividad">
                    <VBox.margin><Insets top="4.0"/></VBox.margin>
                </Label>
            </children>
        </VBox>

        <VBox layoutX="180.0" layoutY="0.0" prefHeight="550.0" prefWidth="520.0"
              spacing="8.0" style="-fx-padding: 25;">
            <children>

                <Label style="-fx-font-size: 22; -fx-font-weight: bold;" text="Registrar Actividad" />

                <VBox fx:id="panelError" managed="false" prefWidth="450.0" spacing="4.0"
                      style="-fx-border-color: #8B0000; -fx-border-width: 2; -fx-background-color: #f5f5dc; -fx-padding: 10;"
                      visible="false">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label style="-fx-text-fill: #8B0000; -fx-font-size: 14; -fx-font-weight: bold;" text="✖" />
                        <Label fx:id="etiquetaTituloError" style="-fx-font-weight: bold; -fx-text-fill: #8B0000;" text="" />
                    </HBox>
                    <Label fx:id="etiquetaMensajeError" style="-fx-text-fill: #8B0000; -fx-font-size: 11;" text="" />
                </VBox>

                <VBox fx:id="panelExito" managed="false" prefWidth="450.0" spacing="4.0"
                      style="-fx-border-color: #2d6a2d; -fx-border-width: 2; -fx-background-color: #f0f7f0; -fx-padding: 10;"
                      visible="false">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label style="-fx-text-fill: #2d6a2d; -fx-font-size: 14; -fx-font-weight: bold;" text="✔" />
                        <Label fx:id="etiquetaTituloExito" style="-fx-font-weight: bold; -fx-text-fill: #2d6a2d;" text="" />
                    </HBox>
                    <Label fx:id="etiquetaMensajeExito" style="-fx-text-fill: #2d6a2d; -fx-font-size: 11;" text="" />
                </VBox>

                <Label style="-fx-font-size: 13;" text="Título de la actividad">
                    <VBox.margin><Insets top="6.0"/></VBox.margin>
                </Label>
                <TextField fx:id="campoTextoTitulo" prefHeight="30.0" prefWidth="450.0"
                           promptText="Ej. Reunión de seguimiento con tutor" />

                <Label style="-fx-font-size: 13;" text="Descripción" />
                <TextField fx:id="campoTextoDescripcion" prefHeight="30.0" prefWidth="450.0"
                           promptText="Describe brevemente la actividad realizada" />

                <HBox spacing="15.0">
                    <VBox>
                        <Label style="-fx-font-size: 13;" text="Fecha de inicio" />
                        <DatePicker fx:id="campoTextoFechaInicio" prefHeight="30.0" prefWidth="210.0"
                                    promptText="Selecciona fecha">
                            <VBox.margin><Insets top="4.0"/></VBox.margin>
                        </DatePicker>
                    </VBox>
                    <VBox>
                        <Label style="-fx-font-size: 13;" text="Fecha de fin" />
                        <DatePicker fx:id="campoTextoFechaFin" prefHeight="30.0" prefWidth="210.0"
                                    promptText="Selecciona fecha">
                            <VBox.margin><Insets top="4.0"/></VBox.margin>
                        </DatePicker>
                    </VBox>
                </HBox>

                <Label style="-fx-font-size: 13;" text="Horas de actividad (máx. 8 por día)" />
                <TextField fx:id="campoTextoHoras" prefHeight="30.0" prefWidth="450.0"
                           promptText="Ej. 4" />

                <HBox spacing="15.0">
                    <VBox.margin><Insets top="15.0"/></VBox.margin>
                    <Button onAction="#botonRegistrar" prefHeight="35.0" prefWidth="140.0"
                            style="-fx-background-color: #2c3e50; -fx-text-fill: white; -fx-background-radius: 6;"
                            text="Registrar" />
                    <Button onAction="#botonCancelar" prefHeight="35.0" prefWidth="140.0"
                            style="-fx-background-color: #c0392b; -fx-text-fill: white; -fx-background-radius: 6;"
                            text="Cancelar" />
                </HBox>

            </children>
        </VBox>

        <Button layoutX="610.0" layoutY="10.0" onAction="#botonRegresar"
                prefHeight="28.0" prefWidth="75.0"
                style="-fx-background-color: #7f8c8d; -fx-text-fill: white; -fx-background-radius: 6;"
                text="Regresar" />

    </children>
</AnchorPane>