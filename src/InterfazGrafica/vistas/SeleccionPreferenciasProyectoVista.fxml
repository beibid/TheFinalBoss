<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="550.0" prefWidth="600.0"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="InterfazGrafica.SeleccionarPreferenciasProyectoControlador">
    <children>

        <VBox layoutX="0.0" layoutY="0.0" prefHeight="550.0" prefWidth="600.0"
              spacing="15.0" style="-fx-border-color: black; -fx-padding: 30;">
            <children>

                <Label style="-fx-font-size: 22; -fx-font-weight: bold;"
                       text="Selección de Proyectos Preferidos" />


                <VBox fx:id="panelError" managed="false" prefWidth="500.0" spacing="4.0"
                      style="-fx-border-color: #8B0000; -fx-border-width: 2; -fx-background-color: #f5f5dc; -fx-padding: 10;"
                      visible="false">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label style="-fx-text-fill: #8B0000; -fx-font-size: 14; -fx-font-weight: bold;" text="✖" />
                        <Label fx:id="etiquetaTituloError" style="-fx-font-weight: bold; -fx-text-fill: #8B0000;" text="" />
                    </HBox>
                    <Label fx:id="etiquetaMensajeError" style="-fx-text-fill: #8B0000; -fx-font-size: 11;" text="" />
                </VBox>

                <!-- Panel éxito -->
                <VBox fx:id="panelExito" managed="false" prefWidth="500.0" spacing="4.0"
                      style="-fx-border-color: #2d6a2d; -fx-border-width: 2; -fx-background-color: #f0f7f0; -fx-padding: 10;"
                      visible="false">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label style="-fx-text-fill: #2d6a2d; -fx-font-size: 14; -fx-font-weight: bold;" text="✔" />
                        <Label fx:id="etiquetaTituloExito" style="-fx-font-weight: bold; -fx-text-fill: #2d6a2d;" text="" />
                    </HBox>
                    <Label fx:id="etiquetaMensajeExito" style="-fx-text-fill: #2d6a2d; -fx-font-size: 11;" text="" />
                </VBox>

                <!-- Prioridad 1 -->
                <VBox spacing="5">
                    <Label style="-fx-font-size: 13; -fx-font-weight: bold;"
                           text=" primera opción " />
                    <ComboBox fx:id="comboBoxPrimerPrioridad" onAction="#validarSeleccion"
                              prefWidth="500.0" promptText="-- Selecciona tu proyecto favorito --" />
                </VBox>

                <!-- Prioridad 2 -->
                <VBox spacing="5">
                    <Label style="-fx-font-size: 13; -fx-font-weight: bold;"
                           text=" segunda opción " />
                    <ComboBox fx:id="comboBoxSegundaPrioridad" onAction="#validarSeleccion"
                              prefWidth="500.0" promptText="-- Selecciona tu segunda opción --" />
                </VBox>

                <!-- Prioridad 3 -->
                <VBox spacing="5">
                    <Label style="-fx-font-size: 13; -fx-font-weight: bold;"
                           text=" tercera opcion " />
                    <ComboBox fx:id="comboBoxTerceraPrioridad" onAction="#validarSeleccion"
                              prefWidth="500.0" promptText="-- Selecciona tu tercera opción --" />
                </VBox>

                <!-- Botones -->
                <HBox spacing="15.0">
                    <VBox.margin><Insets top="10.0" /></VBox.margin>
                    <Button onAction="#botonGuardar" prefHeight="35.0" prefWidth="160.0"
                            style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-background-radius: 6;"
                            text="Guardar preferencias" />
                    <Button onAction="#botonLimpiar" prefHeight="35.0" prefWidth="140.0"
                            style="-fx-background-color: #7f8c8d; -fx-text-fill: white; -fx-background-radius: 6;"
                            text="Cancelar" />
                </HBox>

            </children>
        </VBox>

        <Button layoutX="510.0" layoutY="10.0" onAction="#botonRegresar"
                prefHeight="28.0" prefWidth="75.0"
                style="-fx-background-color: #7f8c8d; -fx-text-fill: white; -fx-background-radius: 6;"
                text="Regresar" />

    </children>
</AnchorPane>