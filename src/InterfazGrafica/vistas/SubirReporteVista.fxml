<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="550.0" prefWidth="750.0"
            xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="InterfazGrafica.SubirReporteControlGUI">
    <children>

        <VBox layoutX="0.0" layoutY="0.0" prefHeight="550.0" prefWidth="180.0"
              style="-fx-background-color: #3a3a3a; -fx-padding: 15;">
            <children>
                <Label text="Subir" style="-fx-text-fill: white; -fx-font-size: 16; -fx-font-weight: bold;"/>
                <Label text="Reporte" style="-fx-text-fill: #aaaaaa; -fx-font-size: 12;">
                    <VBox.margin><Insets top="4.0"/></VBox.margin>
                </Label>
            </children>
        </VBox>

        <VBox layoutX="180.0" layoutY="0.0" prefWidth="570.0" spacing="8.0"
              style="-fx-padding: 25;">
            <children>

                <Label style="-fx-font-size: 22; -fx-font-weight: bold;" text="Subir Reporte"/>

                <VBox fx:id="panelError" managed="false" prefWidth="500.0" spacing="4.0"
                      style="-fx-border-color: #8B0000; -fx-border-width: 2; -fx-background-color: #f5f5dc; -fx-padding: 10;"
                      visible="false">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label style="-fx-text-fill: #8B0000; -fx-font-size: 14; -fx-font-weight: bold;" text="✖"/>
                        <Label fx:id="etiquetaTituloError" style="-fx-font-weight: bold; -fx-text-fill: #8B0000;" text=""/>
                    </HBox>
                    <Label fx:id="etiquetaMensajeError" style="-fx-text-fill: #8B0000; -fx-font-size: 11;" text=""/>
                </VBox>

                <VBox fx:id="panelExito" managed="false" prefWidth="500.0" spacing="4.0"
                      style="-fx-border-color: #2d6a2d; -fx-border-width: 2; -fx-background-color: #f0f7f0; -fx-padding: 10;"
                      visible="false">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label style="-fx-text-fill: #2d6a2d; -fx-font-size: 14; -fx-font-weight: bold;" text="✔"/>
                        <Label fx:id="etiquetaTituloExito" style="-fx-font-weight: bold; -fx-text-fill: #2d6a2d;" text=""/>
                    </HBox>
                    <Label fx:id="etiquetaMensajeExito" style="-fx-text-fill: #2d6a2d; -fx-font-size: 11;" text=""/>
                </VBox>

                <Label style="-fx-font-size: 13;" text="Tipo de reporte"/>
                <ComboBox fx:id="comboBoxTipoReporte" prefWidth="500.0"
                          promptText="-- Selecciona el tipo --"/>

                <Label style="-fx-font-size: 13;" text="Descripción"/>
                <TextField fx:id="campoDescripcion" prefHeight="30.0" prefWidth="500.0"
                           promptText="Describe el reporte"/>

                <Label style="-fx-font-size: 13;" text="Número de personal del profesor"/>
                <TextField fx:id="campoNumPersonalProfesor" prefHeight="30.0" prefWidth="500.0"
                           promptText="Ej. PF001"/>

                <Label style="-fx-font-size: 13;" text="Fecha de generación (YYYY-MM-DD)"/>
                <TextField fx:id="campoFechaGeneracion" prefHeight="30.0" prefWidth="500.0"
                           promptText="Ej. 2024-01-15"/>

                <HBox spacing="15.0">
                    <VBox.margin><Insets top="10.0"/></VBox.margin>
                    <Button onAction="#botonSubir" prefHeight="35.0" prefWidth="140.0"
                            style="-fx-background-color: #2c3e50; -fx-text-fill: white; -fx-background-radius: 6;"
                            text="Subir reporte"/>
                    <Button onAction="#botonCancelar" prefHeight="35.0" prefWidth="140.0"
                            style="-fx-background-color: #c0392b; -fx-text-fill: white; -fx-background-radius: 6;"
                            text="Cancelar"/>
                </HBox>

            </children>
        </VBox>

        <Button layoutX="660.0" layoutY="10.0" onAction="#botonRegresar"
                prefHeight="28.0" prefWidth="75.0"
                style="-fx-background-color: #7f8c8d; -fx-text-fill: white; -fx-background-radius: 6;"
                text="Regresar"/>

    </children>
</AnchorPane>