<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="680.0" prefWidth="750.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="InterfazGrafica.MenuPracticanteControlador">
    <children>

        <VBox layoutX="0.0" layoutY="0.0" prefHeight="680.0" prefWidth="200.0" style="-fx-background-color: #2ecc71; -fx-padding: 15;">
            <children>
                <Label style="-fx-text-fill: white; -fx-font-size: 16; -fx-font-weight: bold;" text="Practicante" />
                <Label fx:id="lblNombre" style="-fx-text-fill: white; -fx-font-size: 12;" text="">
                    <VBox.margin><Insets top="4.0" /></VBox.margin>
                </Label>
                <Label fx:id="lblRol" style="-fx-text-fill: white; -fx-font-size: 11; -fx-background-color: #27ae60; -fx-padding: 3 8 3 8; -fx-background-radius: 10;" text="">
                    <VBox.margin><Insets bottom="10.0" top="5.0" /></VBox.margin>
                </Label>

                <Label fx:id="etiquetaEstado" style="-fx-font-size: 11; -fx-font-weight: bold;" text="" visible="false">
                    <VBox.margin><Insets bottom="5.0" /></VBox.margin>
                </Label>

                <Separator><VBox.margin><Insets bottom="10.0" top="5.0" /></VBox.margin></Separator>

                <Label style="-fx-text-fill: white; -fx-font-size: 11;" text="Reporte" />
                <Button fx:id="botonGenerarReporteMensual" onAction="#abrirGenerarReporteMensual" prefWidth="170.0"
                        style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER-LEFT;"
                        text="Generar reporte Mensual">
                    <VBox.margin><Insets top="5.0" /></VBox.margin>
                </Button>
                <Button fx:id="botonReporteParcial" onAction="#abrirGenerarReporteParcial" prefWidth="170.0"
                        style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER-LEFT;"
                        text="Generar reporte Parcial">
                    <VBox.margin><Insets top="5.0" /></VBox.margin>
                </Button>
                <Button fx:id="botonReporteFinal" onAction="#abrirGenerarReporteFinal" prefWidth="170.0"
                        style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER-LEFT;"
                        text="Generar reporte Final">
                    <VBox.margin><Insets top="5.0" /></VBox.margin>
                </Button>
                <Button fx:id="botonSubirReporte" onAction="#abrirSubirReporte" prefWidth="170.0"
                        style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER-LEFT;"
                        text="Subir reporte">
                    <VBox.margin><Insets top="5.0" /></VBox.margin>
                </Button>
                <Button onAction="#abrirMisReportes" prefWidth="170.0"
                        style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER-LEFT;"
                        text="Mis reportes">
                    <VBox.margin><Insets top="3.0" /></VBox.margin>
                </Button>

                <Separator><VBox.margin><Insets bottom="10.0" top="10.0" /></VBox.margin></Separator>

                <Label style="-fx-text-fill: white; -fx-font-size: 11;" text="Documentación" />
                <Button fx:id="botonSubirDocumentacion" onAction="#abrirSubirDocumentacion" prefWidth="170.0"
                        style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER-LEFT;"
                        text="Subir documentación">
                    <VBox.margin><Insets top="5.0" /></VBox.margin>
                </Button>
                <Button onAction="#abrirDescargarDocumentacion" prefWidth="170.0"
                        style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER-LEFT;"
                        text="Descargar documentación">
                    <VBox.margin><Insets top="5.0" /></VBox.margin>
                </Button>

                <Separator><VBox.margin><Insets bottom="10.0" top="10.0" /></VBox.margin></Separator>

                <Label style="-fx-text-fill: white; -fx-font-size: 11;" text="Actividad" />
                <Button fx:id="botonRegistrarActividad" onAction="#abrirRegistrarActividad" prefWidth="170.0"
                        style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER-LEFT;"
                        text="Registrar actividad">
                    <VBox.margin><Insets top="5.0" /></VBox.margin>
                </Button>

                <Separator><VBox.margin><Insets bottom="10.0" top="10.0" /></VBox.margin></Separator>

                <Label style="-fx-text-fill: white; -fx-font-size: 11;" text="Proyecto" />
                <Button fx:id="botonSeleccionarProyectos" onAction="#abrirSeleccionProyectos" prefWidth="170.0"
                        style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER-LEFT;"
                        text="Seleccionar proyectos">
                    <VBox.margin><Insets top="5.0" /></VBox.margin>
                </Button>

                <Separator><VBox.margin><Insets bottom="10.0" top="10.0" /></VBox.margin></Separator>

                <Label style="-fx-text-fill: white; -fx-font-size: 11;" text="Mensajes" />
                <Button onAction="#abrirMensajeria" prefWidth="170.0"
                        style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER-LEFT;"
                        text="Enviar mensaje">
                    <VBox.margin><Insets top="5.0" /></VBox.margin>
                </Button>
                <Button onAction="#abrirBuzon" prefWidth="170.0"
                        style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER-LEFT;"
                        text="Ver buzón">
                    <VBox.margin><Insets top="3.0" /></VBox.margin>
                </Button>

                <Separator><VBox.margin><Insets bottom="10.0" top="10.0" /></VBox.margin></Separator>

                <Label style="-fx-text-fill: white; -fx-font-size: 11;" text="Autoevaluacion" />
                <Button fx:id="botonAutoevaluacion" onAction="#abrirAutoevaluacionPracticante" prefWidth="170.0"
                        style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER-LEFT;"
                        text="Realizar Autoevaluacion">
                    <VBox.margin><Insets top="3.0" /></VBox.margin>
                </Button>

                <Separator><VBox.margin><Insets bottom="10.0" top="10.0" /></VBox.margin></Separator>

                <Button onAction="#cerrarSesion" prefWidth="170.0"
                        style="-fx-background-color: #c0392b; -fx-text-fill: white;"
                        text="Cerrar Sesión">
                    <VBox.margin><Insets top="5.0" /></VBox.margin>
                </Button>
            </children>
        </VBox>

        <VBox alignment="CENTER" layoutX="200.0" layoutY="0.0" prefHeight="680.0" prefWidth="550.0" style="-fx-padding: 30;">
            <children>
                <Label fx:id="lblBienvenida" style="-fx-font-size: 22; -fx-font-weight: bold;" text="" />
                <Label style="-fx-font-size: 13; -fx-text-fill: #666666;" text="Selecciona una opción del menú">
                    <VBox.margin><Insets top="8.0" /></VBox.margin>
                </Label>
            </children>
        </VBox>

    </children>
</AnchorPane>