                            <fx:define><ToggleGroup fx:id="grupoRespuesta10" /></fx:define>
                            <RadioButton prefWidth="30.0" toggleGroup="$grupoRespuesta10" userData="1" />
                            <RadioButton prefWidth="30.0" toggleGroup="$grupoRespuesta10" userData="2" />
                            <RadioButton prefWidth="30.0" toggleGroup="$grupoRespuesta10" userData="3" />
                            <RadioButton prefWidth="30.0" toggleGroup="$grupoRespuesta10" userData="4" />
                            <RadioButton prefWidth="30.0" toggleGroup="$grupoRespuesta10" userData="5" />
