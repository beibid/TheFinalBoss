                        </HBox>
                        <HBox spacing="10.0">
                            <Label style="-fx-font-size: 13; -fx-font-weight: bold;" text="Organización vinculada:" />
                            <Label fx:id="etiquetaOrganizacion" style="-fx-font-size: 13;" text="" />
                        </HBox>
                        <HBox spacing="10.0">
                            <Label style="-fx-font-size: 13; -fx-font-weight: bold;" text="Nombre del proyecto:" />
