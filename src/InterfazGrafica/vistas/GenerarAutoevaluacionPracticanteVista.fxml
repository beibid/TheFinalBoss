                        <HBox spacing="10.0" alignment="CENTER_LEFT">
                            <Label prefWidth="340.0" style="-fx-font-size: 12;" text="7. El Responsable del Proyecto me orientó correctamente para el desarrollo de mis actividades." wrapText="true" />
                            <fx:define><ToggleGroup fx:id="grupoRespuesta7" /></fx:define>
                            <RadioButton prefWidth="30.0" toggleGroup="$grupoRespuesta7" userData="1" />
                            <RadioButton prefWidth="30.0" toggleGroup="$grupoRespuesta7" userData="2" />
                            <RadioButton prefWidth="30.0" toggleGroup="$grupoRespuesta7" userData="3" />
                            <RadioButton prefWidth="30.0" toggleGroup="$grupoRespuesta7" userData="4" />
                            <RadioButton prefWidth="30.0" toggleGroup="$grupoRespuesta7" userData="5" />
                        </HBox>

                        <HBox spacing="10.0" alignment="CENTER_LEFT">
