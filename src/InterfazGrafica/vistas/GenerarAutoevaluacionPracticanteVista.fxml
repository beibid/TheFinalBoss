                            <Label prefWidth="340.0" style="-fx-font-size: 12;" text="3. Me sentí seguro al realizar las actividades encomendadas." wrapText="true" />
                            <fx:define><ToggleGroup fx:id="grupoRespuesta3" /></fx:define>
                            <RadioButton prefWidth="30.0" toggleGroup="$grupoRespuesta3" userData="1" />
                            <RadioButton prefWidth="30.0" toggleGroup="$grupoRespuesta3" userData="2" />
                            <RadioButton prefWidth="30.0" toggleGroup="$grupoRespuesta3" userData="3" />
                            <RadioButton prefWidth="30.0" toggleGroup="$grupoRespuesta3" userData="4" />
                            <RadioButton prefWidth="30.0" toggleGroup="$grupoRespuesta3" userData="5" />
