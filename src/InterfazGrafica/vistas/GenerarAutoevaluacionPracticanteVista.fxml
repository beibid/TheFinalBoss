                            <fx:define><ToggleGroup fx:id="grupoRespuesta6" /></fx:define>
                            <RadioButton prefWidth="30.0" toggleGroup="$grupoRespuesta6" userData="1" />
                            <RadioButton prefWidth="30.0" toggleGroup="$grupoRespuesta6" userData="2" />
                            <RadioButton prefWidth="30.0" toggleGroup="$grupoRespuesta6" userData="3" />
                            <RadioButton prefWidth="30.0" toggleGroup="$grupoRespuesta6" userData="4" />
                            <RadioButton prefWidth="30.0" toggleGroup="$grupoRespuesta6" userData="5" />
