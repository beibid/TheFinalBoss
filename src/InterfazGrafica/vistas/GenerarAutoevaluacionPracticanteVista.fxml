                            <RadioButton prefWidth="30.0" toggleGroup="$grupoRespuesta2" userData="2" />
                            <RadioButton prefWidth="30.0" toggleGroup="$grupoRespuesta2" userData="3" />
                            <RadioButton prefWidth="30.0" toggleGroup="$grupoRespuesta2" userData="4" />
                            <RadioButton prefWidth="30.0" toggleGroup="$grupoRespuesta2" userData="5" />
