                            <RadioButton prefWidth="30.0" toggleGroup="$grupoRespuesta8" userData="3" />
                            <RadioButton prefWidth="30.0" toggleGroup="$grupoRespuesta8" userData="4" />
                            <RadioButton prefWidth="30.0" toggleGroup="$grupoRespuesta8" userData="5" />
