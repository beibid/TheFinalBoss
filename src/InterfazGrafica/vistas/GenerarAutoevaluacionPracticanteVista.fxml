                        </Separator>

                        <HBox spacing="15.0">
                            <VBox.margin><Insets top="10.0" /></VBox.margin>
                            <Button fx:id="botonGuardar" onAction="#botonGuardar" prefHeight="35.0" prefWidth="140.0" style="-fx-background-color: #2c3e50; -fx-text-fill: white; -fx-background-radius: 6;" text="Guardar" />
                            <Button fx:id="botonGenerarPDF" onAction="#botonGenerarPDF" prefHeight="35.0" prefWidth="140.0" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-background-radius: 6;" text="Generar PDF" />
                            <Button fx:id="botonCancelar" onAction="#botonCancelar" prefHeight="35.0" prefWidth="140.0" style="-fx-background-color: #c0392b; -fx-text-fill: white; -fx-background-radius: 6;" text="Cancelar" />
