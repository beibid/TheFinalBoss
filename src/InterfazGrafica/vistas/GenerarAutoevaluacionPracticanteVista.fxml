                            <Label prefWidth="340.0" style="-fx-font-size: 12;" text="9. El proyecto es congruente con la formación de mi carrera." wrapText="true" />
                            <fx:define><ToggleGroup fx:id="grupoRespuesta9" /></fx:define>
                            <RadioButton prefWidth="30.0" toggleGroup="$grupoRespuesta9" userData="1" />
                            <RadioButton prefWidth="30.0" toggleGroup="$grupoRespuesta9" userData="2" />
                            <RadioButton prefWidth="30.0" toggleGroup="$grupoRespuesta9" userData="3" />
                            <RadioButton prefWidth="30.0" toggleGroup="$grupoRespuesta9" userData="4" />
                            <RadioButton prefWidth="30.0" toggleGroup="$grupoRespuesta9" userData="5" />
