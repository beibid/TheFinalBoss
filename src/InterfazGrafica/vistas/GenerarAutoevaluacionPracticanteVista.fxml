<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="650.0" prefWidth="750.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="InterfazGrafica.GenerarAutoevaluacionPracticanteControlador">
    <children>

        <VBox layoutX="0.0" layoutY="0.0" prefHeight="650.0" prefWidth="180.0" style="-fx-background-color: #2ecc71; -fx-padding: 15;">
            <children>
                <Label style="-fx-text-fill: white; -fx-font-size: 16; -fx-font-weight: bold;" text="Autoevaluación" />
                <Label style="-fx-text-fill: black; -fx-font-size: 12;" text="Practicante">
                    <VBox.margin><Insets top="4.0" /></VBox.margin>
                </Label>
            </children>
        </VBox>

        <ScrollPane fitToWidth="true" layoutX="180.0" layoutY="0.0" prefHeight="650.0" prefWidth="570.0">
