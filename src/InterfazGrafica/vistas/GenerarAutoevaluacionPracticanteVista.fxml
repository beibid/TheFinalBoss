                            <RadioButton prefWidth="30.0" toggleGroup="$grupoRespuesta1" userData="2" />
                            <RadioButton prefWidth="30.0" toggleGroup="$grupoRespuesta1" userData="3" />
                            <RadioButton prefWidth="30.0" toggleGroup="$grupoRespuesta1" userData="4" />
                            <RadioButton prefWidth="30.0" toggleGroup="$grupoRespuesta1" userData="5" />
