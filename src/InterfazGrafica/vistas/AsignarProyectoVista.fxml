<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="500.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="InterfazGrafica.AsignarProyectoControlador">
    <children>

        <VBox layoutX="0.0" layoutY="0.0" prefHeight="500.0" prefWidth="600.0" spacing="15.0" style="-fx-border-color: black;-fx-padding: 30;">
            <children>

                <Label style="-fx-font-size: 22; -fx-font-weight: bold;" text="Asignar Proyecto a Practicante" />

                <VBox fx:id="panelError" managed="false" prefWidth="500.0" spacing="4.0" style="-fx-border-color: #8B0000; -fx-border-width: 2; -fx-background-color: #f5f5dc; -fx-padding: 10;" visible="false">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label style="-fx-text-fill: #8B0000; -fx-font-size: 14; -fx-font-weight: bold;" text="✖" />
                        <Label fx:id="etiquetaTituloError" style="-fx-font-weight: bold; -fx-text-fill: #8B0000;" text="" />
                    </HBox>
                    <Label fx:id="etiquetaMensajeError" style="-fx-text-fill: #8B0000; -fx-font-size: 11;" text="" />
                </VBox>

                <VBox fx:id="panelExito" managed="false" prefWidth="500.0" spacing="4.0" style="-fx-border-color: #2d6a2d; -fx-border-width: 2; -fx-background-color: #f0f7f0; -fx-padding: 10;" visible="false">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label style="-fx-text-fill: #2d6a2d; -fx-font-size: 14; -fx-font-weight: bold;" text="✔" />
                        <Label fx:id="etiquetaTituloExito" style="-fx-font-weight: bold; -fx-text-fill: #2d6a2d;" text="" />
                    </HBox>
                    <Label fx:id="etiquetaMensajeExito" style="-fx-text-fill: #2d6a2d; -fx-font-size: 11;" text="" />
                </VBox>

                <VBox spacing="5">
                    <Label style="-fx-font-size: 13;" text="Selecciona un practicante activo" />
                    <ComboBox fx:id="comboBoxPracticantes" onAction="#seleccionarPracticante" prefWidth="500.0" promptText="-- Selecciona un practicante --" />
                </VBox>

                <VBox spacing="5">
                    <Label style="-fx-font-size: 13;" text="Selecciona un proyecto disponible" />
                    <ComboBox fx:id="comboBoxProyectos" prefWidth="500.0" promptText="-- Selecciona proyecto --" />
                </VBox>

                <HBox spacing="15.0">
                    <VBox.margin><Insets top="10.0" /></VBox.margin>
                    <Button fx:id="botonAsignar" onAction="#botonAsignar" prefHeight="35.0" prefWidth="140.0" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-background-radius: 6;" text="Asignar" />
                    <Button fx:id="botonCancelar" onAction="#botonCancelar" prefHeight="35.0" prefWidth="140.0" style="-fx-background-color: #7f8c8d; -fx-text-fill: white; -fx-background-radius: 6;" text="Cancelar" />
                </HBox>

            </children>
        </VBox>

        <Button fx:id="botonRegresar" layoutX="510.0" layoutY="10.0" onAction="#botonRegresar" prefHeight="28.0" prefWidth="75.0" style="-fx-background-color: #7f8c8d; -fx-text-fill: white; -fx-background-radius: 6;" text="Regresar" />

    </children>
</AnchorPane>
