<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="600.0" prefWidth="750.0"
            xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="InterfazGrafica.BuzonControlGUI">
    <children>

        <VBox layoutX="0.0" layoutY="0.0" prefHeight="600.0" prefWidth="180.0"
              style="-fx-background-color: #2ecc71; -fx-padding: 15;">
            <children>
                <Label text="Mensajería" style="-fx-text-fill: white; -fx-font-size: 16; -fx-font-weight: bold;"/>
                <Label text="Buzón" style="-fx-text-fill: black; -fx-font-size: 12;">
                    <VBox.margin><Insets top="4.0"/></VBox.margin>
                </Label>
            </children>
        </VBox>

        <VBox layoutX="180.0" layoutY="0.0" prefHeight="600.0" prefWidth="570.0"
              style="-fx-padding: 25;" spacing="10.0">
            <children>

                <Label text="Buzón de Mensajes" style="-fx-font-size: 22; -fx-font-weight: bold;"/>

                <TabPane fx:id="tabPane" prefHeight="320.0" prefWidth="520.0">
                    <tabs>
                        <Tab text="Recibidos" closable="false">
                            <content>
                                <TableView fx:id="tablaRecibidos" prefHeight="280.0" prefWidth="520.0"
                                           onMouseClicked="#seleccionarMensajeRecibido">
                                    <columns>
                                        <TableColumn fx:id="columnaRemitenteRecibidos" text="Remitente" prefWidth="200.0"/>
                                        <TableColumn fx:id="columnaFechaRecibidos" text="Fecha" prefWidth="150.0"/>
                                        <TableColumn fx:id="columnaContenidoRecibidos" text="Contenido" prefWidth="168.0"/>
                                    </columns>
                                </TableView>
                            </content>
                        </Tab>
                        <Tab text="Enviados" closable="false">
                            <content>
                                <TableView fx:id="tablaEnviados" prefHeight="280.0" prefWidth="520.0"
                                           onMouseClicked="#seleccionarMensajeEnviado">
                                    <columns>
                                        <TableColumn fx:id="columnaDestinatarioEnviados" text="Destinatario" prefWidth="200.0"/>
                                        <TableColumn fx:id="columnaFechaEnviados" text="Fecha" prefWidth="150.0"/>
                                        <TableColumn fx:id="columnaContenidoEnviados" text="Contenido" prefWidth="168.0"/>
                                    </columns>
                                </TableView>
                            </content>
                        </Tab>
                    </tabs>
                </TabPane>

                <Label text="Contenido del mensaje" style="-fx-font-size: 13; -fx-font-weight: bold;"/>
                <TextArea fx:id="areaContenidoMensaje" prefHeight="120.0" prefWidth="520.0"
                          editable="false" wrapText="true"
                          promptText="Selecciona un mensaje para ver su contenido..."/>

                <Button onAction="#botonRegresar" prefHeight="30.0" prefWidth="100.0"
                        text="Regresar"
                        style="-fx-background-color: #7f8c8d; -fx-text-fill: white; -fx-background-radius: 6;"/>

            </children>
        </VBox>

    </children>
</AnchorPane>