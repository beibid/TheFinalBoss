<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.geometry.Insets?>

<AnchorPane prefHeight="450.0" prefWidth="600.0"
            xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="InterfazGrafica.InactivarProfesorControlador">
    <children>

        <VBox layoutX="0.0" layoutY="0.0" prefHeight="450.0" prefWidth="600.0"
              style="-fx-padding: 30;" spacing="15.0">
            <children>

                <Label text="Inactivar Profesor" style="-fx-font-size: 22; -fx-font-weight: bold;"/>


                <VBox fx:id="panelError" managed="false" prefWidth="500.0" spacing="4.0"
                      style="-fx-border-color: #8B0000; -fx-border-width: 2; -fx-background-color: #f5f5dc; -fx-padding: 10;"
                      visible="false">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label text="✖" style="-fx-text-fill: #8B0000; -fx-font-size: 14; -fx-font-weight: bold;"/>
                        <Label fx:id="etiquetaTituloError" style="-fx-font-weight: bold; -fx-text-fill: #8B0000;" text=""/>
                    </HBox>
                    <Label fx:id="etiquetaMensajeError" style="-fx-text-fill: #8B0000; -fx-font-size: 11;" text=""/>
                </VBox>


                <VBox fx:id="panelExito" managed="false" prefWidth="500.0" spacing="4.0"
                      style="-fx-border-color: #2d6a2d; -fx-border-width: 2; -fx-background-color: #f0f7f0; -fx-padding: 10;"
                      visible="false">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label text="✔" style="-fx-text-fill: #2d6a2d; -fx-font-size: 14; -fx-font-weight: bold;"/>
                        <Label fx:id="etiquetaTituloExito" style="-fx-font-weight: bold; -fx-text-fill: #2d6a2d;" text=""/>
                    </HBox>
                    <Label fx:id="etiquetaMensajeExito" style="-fx-text-fill: #2d6a2d; -fx-font-size: 11;" text=""/>
                </VBox>

                <Label text="Selecciona un profesor activo" style="-fx-font-size: 13;"/>
                <ComboBox fx:id="comboBoxProfesores" prefWidth="500.0" promptText="-- Selecciona un profesor --"
                          onAction="#seleccionarProfesor"/>

                <VBox fx:id="panelDatos" managed="false" visible="false" spacing="8.0"
                      style="-fx-border-color: #cccccc; -fx-border-width: 1; -fx-padding: 15; -fx-background-color: #f9f9f9;">
                    <Label text="Datos del profesor" style="-fx-font-weight: bold; -fx-font-size: 13;"/>
                    <HBox spacing="10.0">
                        <Label text="Nombre:" style="-fx-font-weight: bold;"/>
                        <Label fx:id="etiquetaNombre" text=""/>
                    </HBox>
                    <HBox spacing="10.0">
                        <Label text="Apellidos:" style="-fx-font-weight: bold;"/>
                        <Label fx:id="etiquetaApellidos" text=""/>
                    </HBox>
                    <HBox spacing="10.0">
                        <Label text="Número de personal:" style="-fx-font-weight: bold;"/>
                        <Label fx:id="etiquetaNumeroPersonal" text=""/>
                    </HBox>
                </VBox>

                <HBox spacing="15.0">
                    <VBox.margin><Insets top="10.0"/></VBox.margin>
                    <Button fx:id="botonInactivar" onAction="#botonInactivar" prefWidth="140.0" prefHeight="35.0"
                            text="Inactivar"
                            style="-fx-background-color: #c0392b; -fx-text-fill: white; -fx-background-radius: 6;"/>
                    <Button fx:id="botonCancelar" onAction="#botonCancelar" prefWidth="140.0" prefHeight="35.0"
                            text="Cancelar"
                            style="-fx-background-color: #7f8c8d; -fx-text-fill: white; -fx-background-radius: 6;"/>
                </HBox>

            </children>
        </VBox>

        <Button fx:id="botonRegresar" layoutX="510.0" layoutY="10.0" onAction="#botonRegresar"
                prefHeight="28.0" prefWidth="75.0" text="Regresar"
                style="-fx-background-color: #7f8c8d; -fx-text-fill: white; -fx-background-radius: 6;"/>

    </children>
</AnchorPane>